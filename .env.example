# LLM Configuration for Lab 24 Evaluation
# Use GPT-4o-mini for judge logic and decision-making
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_JUDGE_MODEL=gpt-4o-mini

# Optional: Groq for edge-case safety filtering
GROQ_API_KEY=your_groq_api_key_here
GROQ_GUARD_MODEL=llama-3.1-8b-instant
USE_GROQ_GUARD=false

# Enable live LLM judging (false = local deterministic fallback)
USE_LLM_JUDGE=false

# Advanced tracing and analytics (optional)
LANGSMITH_API_KEY=your_langsmith_key

# Enable Presidio for production PII detection (false = regex only)
USE_PRESIDIO=false
